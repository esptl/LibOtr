<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Esp.ThirdParty.LibOtr</RootNamespace>
    <AssemblyName>Esp.ThirdParty.LibOtr.Managed</AssemblyName>
    <Platforms>AnyCPU;x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Pure-IL layer over the net10 mixed-mode C++/CLI wrapper (built separately). -->
    <Reference Include="Esp.ThirdParty.LibOtr">
      <HintPath>..\x64\Release\Esp.ThirdParty.LibOtr.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
